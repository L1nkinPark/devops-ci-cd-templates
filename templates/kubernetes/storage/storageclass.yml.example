# =============================================================================
# Template: Kubernetes StorageClass (NFS Storage)
# -----------------------------------------------------------------------------
# StorageClass cau hinh cach cap phat storage cho PersistentVolume (PV).
# Su dung provisioner: kubernetes.io/no-provisioner (manual provisioning)
# thuong dung cho NFS shares duoc tu tao hoac local storage.
#
# Huong dan:
#   1. Copy file nay va doi ten bo .example
#   2. Apply:
#      kubectl apply -f storageclass.yml
#   3. Kiem tra:
#      kubectl get sc
#
# Luu y:
#   - volumeBindingMode: WaitForFirstConsumer dam bao PV/PVC chi bind
#     khi co Pod thuc su su dung va duoc len lich (scheduled).
# =============================================================================

apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: nfs-storage
provisioner: kubernetes.io/no-provisioner
volumeBindingMode: WaitForFirstConsumer
